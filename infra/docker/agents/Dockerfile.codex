FROM node:22-slim

# Install codex CLI globally
RUN npm install -g @openai/codex

# Create workspace mount point
RUN mkdir -p /workspace
WORKDIR /workspace

# Run as non-root user for safety
RUN useradd -m -u 1001 agent
RUN chown -R agent:agent /workspace
USER agent

ENTRYPOINT ["codex"]
CMD ["--help"]
