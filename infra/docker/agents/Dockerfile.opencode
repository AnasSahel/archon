FROM debian:bookworm-slim

ARG OPENCODE_VERSION=1.3.15

RUN apt-get update && apt-get install -y curl ca-certificates && rm -rf /var/lib/apt/lists/*
RUN curl -fsSL "https://github.com/sst/opencode/releases/download/v${OPENCODE_VERSION}/opencode-linux-x64.tar.gz" \
    | tar -xz -C /usr/local/bin opencode && chmod +x /usr/local/bin/opencode

# Create workspace mount point
RUN mkdir -p /workspace && useradd -m -u 1001 agent && chown -R agent:agent /workspace
WORKDIR /workspace
USER agent

ENTRYPOINT ["opencode"]
CMD ["--help"]
