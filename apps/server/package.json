{
  "name": "@archon/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test:run": "vitest run",
    "test": "vitest",
    "db:seed": "tsx src/seed.ts",
    "db:seed-streaming": "tsx src/seed-streaming.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@archon/ai": "workspace:^",
    "@archon/context": "workspace:^",
    "@archon/db": "workspace:^",
    "@archon/hitl": "workspace:^",
    "@archon/notifications": "workspace:^",
    "@archon/sandbox": "workspace:^",
    "@archon/shared": "workspace:*",
    "@archon/tool-policy": "workspace:^",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.7.6",
    "ai": "^4.0.0",
    "better-auth": "^1.5.6",
    "bullmq": "^5.0.0",
    "dockerode": "^4.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.1",
    "hono": "^4.6.16",
    "ioredis": "^5.3.0",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "resend": "^6.10.0",
    "xstate": "^5.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
