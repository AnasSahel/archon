{
  "name": "archon",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test:run": "turbo run test:run",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "infra:up": "docker compose -f infra/docker/docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f infra/docker/docker-compose.dev.yml down",
    "infra:reset": "docker compose -f infra/docker/docker-compose.dev.yml down -v && docker compose -f infra/docker/docker-compose.dev.yml up -d",
    "db:generate": "turbo run db:generate --filter=@archon/db",
    "db:migrate": "turbo run db:migrate --filter=@archon/db",
    "db:studio": "turbo run db:studio --filter=@archon/db"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.2"
  }
}
